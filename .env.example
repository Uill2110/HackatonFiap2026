# Provedor de LLM para o texto do relatório (resumo + recomendações).
# Opcional — o padrão é "anthropic" (Claude). Use "openai" para gerar com GPT.
LLM_PROVIDER=anthropic

# --- Anthropic (Claude) — usado quando LLM_PROVIDER=anthropic (padrão) ---
ANTHROPIC_API_KEY=sk-...
# Opcional: sobrescreve o modelo Claude (padrão: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (GPT) — usado quando LLM_PROVIDER=openai ---
# OPENAI_API_KEY=sk-...
# Opcional: sobrescreve o modelo OpenAI (padrão: gpt-4o)
# OPENAI_MODEL=gpt-4o

# --- Detecção / relatório ---
ROBOFLOW_API_KEY=rf_...
MODEL_WEIGHTS_PATH=model/weights/best.pt
REPORT_OUTPUT_DIR=docs/exemplos_relatorio/
